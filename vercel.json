{
  "version": 2,
  "buildCommand": "CI=false npm run build",
  "outputDirectory": "build",
  "env": {
    "REACT_APP_ENVIRONMENT": "production"
  },
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "^/static/(.*)$",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "max-age=31536000, immutable"
      }
    },
    {
      "src": "^/docs/(.*)$",
      "dest": "/docs/$1",
      "headers": {
        "Content-Disposition": "attachment"
      }
    },
    {
      "src": "^/.*",
      "dest": "/index.html"
    }
  ],
  "rewrites": []
}